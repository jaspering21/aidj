# AIDJ Environment Configuration Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# MiniMax API Key (get from https://platform.minimax.chat/)
MINIMAX_API_KEY=your_api_key_here

# NetEase Music Cookie (from browser developer tools)
# Leave empty to use cached session from ~/.aidj/secrets.json
NETEASE_COOKIE=

# Optional: Custom playlist ID
# PLAYLIST_ID=2205555594
